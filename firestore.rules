rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasEmail() {
      return isSignedIn() && request.auth.token.email is string;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function allowedUserPath() {
      return /databases/$(database)/documents/allowedUsers/$(userEmail());
    }

    function isAllowed() {
      return hasEmail()
        && exists(allowedUserPath())
        && get(allowedUserPath()).data.active == true
        && get(allowedUserPath()).data.role in ['admin', 'member'];
    }

    function isAdmin() {
      return isAllowed() && get(allowedUserPath()).data.role == 'admin';
    }

    function isOptionalString(data, field, maxLength) {
      return data.get(field, null) == null
        || (data.get(field, null) is string && data.get(field, null).size() <= maxLength);
    }

    function isOptionalNumber(data, field) {
      return data.get(field, null) == null || data.get(field, null) is number;
    }

    function isOptionalTimestamp(data, field) {
      return data.get(field, null) == null || data.get(field, null) is timestamp;
    }

    function isOptionalBool(data, field) {
      return data.get(field, null) == null || data.get(field, null) is bool;
    }

    function validCreateMetadata() {
      return request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == userEmail()
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validUpdateMetadata() {
      return request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function validAllowedUser(email) {
      let data = request.resource.data;
      return email == email.lower()
        && data.keys().hasOnly(['email', 'displayName', 'role', 'active', 'createdByEmail', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['email', 'displayName', 'role', 'active', 'createdByEmail', 'createdAt', 'updatedAt'])
        && data.email == email
        && data.email is string
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 160
        && data.role in ['admin', 'member']
        && data.active is bool
        && data.createdByEmail is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /allowedUsers/{email} {
      allow get: if hasEmail() && email == userEmail();
      allow list: if isAdmin();
      allow create: if isAdmin()
        && validAllowedUser(email)
        && request.resource.data.createdByEmail == userEmail()
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isAdmin()
        && validAllowedUser(email)
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && (email != userEmail()
          || (request.resource.data.role == resource.data.role
            && request.resource.data.active == true));
      allow delete: if isAdmin() && email != userEmail();
    }

    function validBaby() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'name', 'nickname', 'gender', 'birthDate', 'birthTime', 'birthWeight', 'birthHeight',
          'birthHeadCircumference', 'gestationalWeeks', 'bloodType', 'hospital', 'avatarUrl',
          'allergiesSummary', 'emergencyContact', 'notes',
          'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll(['name', 'birthDate', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 160
        && data.birthDate is string && data.birthDate.size() == 10
        && isOptionalString(data, 'nickname', 100)
        && (data.get('gender', '') in ['', 'female', 'male', 'other'])
        && isOptionalString(data, 'birthTime', 5)
        && isOptionalNumber(data, 'birthWeight')
        && isOptionalNumber(data, 'birthHeight')
        && isOptionalNumber(data, 'birthHeadCircumference')
        && isOptionalNumber(data, 'gestationalWeeks')
        && isOptionalString(data, 'bloodType', 10)
        && isOptionalString(data, 'hospital', 250)
        && isOptionalString(data, 'avatarUrl', 1000)
        && isOptionalString(data, 'allergiesSummary', 1000)
        && isOptionalString(data, 'emergencyContact', 300)
        && isOptionalString(data, 'notes', 1500);
    }

    match /babies/{babyId} {
      allow read: if isAllowed();
      allow create: if isAllowed() && validBaby() && validCreateMetadata();
      allow update: if isAllowed() && validBaby() && validUpdateMetadata();
      allow delete: if isAllowed();

      match /growthRecords/{recordId} {
        function validGrowth() {
          let data = request.resource.data;
          return data.keys().hasOnly(['measuredAt', 'weightKg', 'heightCm', 'headCircumferenceCm', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['measuredAt', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.measuredAt is timestamp
            && isOptionalNumber(data, 'weightKg')
            && isOptionalNumber(data, 'heightCm')
            && isOptionalNumber(data, 'headCircumferenceCm')
            && isOptionalString(data, 'notes', 1000)
            && (data.get('weightKg', null) != null || data.get('heightCm', null) != null || data.get('headCircumferenceCm', null) != null);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validGrowth() && validCreateMetadata();
        allow update: if isAllowed() && validGrowth() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /vaccinations/{recordId} {
        function validVaccination() {
          let data = request.resource.data;
          return data.keys().hasOnly(['vaccineName', 'diseasePrevention', 'doseNumber', 'scheduledDate', 'administeredDate', 'status', 'clinic', 'provider', 'batchNumber', 'reactions', 'documentUrl', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['vaccineName', 'doseNumber', 'scheduledDate', 'status', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.vaccineName is string && data.vaccineName.size() > 0 && data.vaccineName.size() <= 160
            && data.doseNumber is number && data.doseNumber >= 1
            && data.scheduledDate is timestamp
            && isOptionalTimestamp(data, 'administeredDate')
            && data.status in ['scheduled', 'upcoming', 'completed', 'overdue', 'cancelled']
            && isOptionalString(data, 'diseasePrevention', 250)
            && isOptionalString(data, 'clinic', 250)
            && isOptionalString(data, 'provider', 160)
            && isOptionalString(data, 'batchNumber', 100)
            && isOptionalString(data, 'reactions', 1000)
            && isOptionalString(data, 'documentUrl', 1000)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validVaccination() && validCreateMetadata();
        allow update: if isAllowed() && validVaccination() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /medicalVisits/{recordId} {
        function validMedicalVisit() {
          let data = request.resource.data;
          return data.keys().hasOnly(['visitDate', 'reason', 'symptoms', 'temperatureCelsius', 'weightKg', 'doctorName', 'facility', 'diagnosisByDoctor', 'treatmentPlan', 'followUpDate', 'prescriptionUrl', 'testResultUrl', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['visitDate', 'reason', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.visitDate is timestamp
            && data.reason is string && data.reason.size() > 0 && data.reason.size() <= 300
            && isOptionalString(data, 'symptoms', 1500)
            && isOptionalNumber(data, 'temperatureCelsius')
            && isOptionalNumber(data, 'weightKg')
            && isOptionalString(data, 'doctorName', 160)
            && isOptionalString(data, 'facility', 250)
            && isOptionalString(data, 'diagnosisByDoctor', 1500)
            && isOptionalString(data, 'treatmentPlan', 2000)
            && isOptionalTimestamp(data, 'followUpDate')
            && isOptionalString(data, 'prescriptionUrl', 1000)
            && isOptionalString(data, 'testResultUrl', 1000)
            && isOptionalString(data, 'notes', 1500);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validMedicalVisit() && validCreateMetadata();
        allow update: if isAllowed() && validMedicalVisit() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /feedingRecords/{recordId} {
        function validFeeding() {
          let data = request.resource.data;
          return data.keys().hasOnly(['feedingType', 'startedAt', 'endedAt', 'amount', 'unit', 'breastSide', 'foodName', 'ingredients', 'allergyReaction', 'reactionDetails', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['feedingType', 'startedAt', 'allergyReaction', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.feedingType in ['breastfeeding', 'breast_milk_bottle', 'formula', 'solid_food', 'water', 'other']
            && data.startedAt is timestamp
            && isOptionalTimestamp(data, 'endedAt')
            && isOptionalNumber(data, 'amount')
            && isOptionalString(data, 'unit', 30)
            && (data.get('breastSide', null) == null || data.get('breastSide', null) in ['left', 'right', 'both'])
            && isOptionalString(data, 'foodName', 250)
            && isOptionalString(data, 'ingredients', 1000)
            && data.allergyReaction is bool
            && isOptionalString(data, 'reactionDetails', 1000)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validFeeding() && validCreateMetadata();
        allow update: if isAllowed() && validFeeding() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /sleepRecords/{recordId} {
        function validSleep() {
          let data = request.resource.data;
          return data.keys().hasOnly(['startedAt', 'endedAt', 'sleepType', 'wakeCount', 'quality', 'location', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['startedAt', 'endedAt', 'sleepType', 'wakeCount', 'quality', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.startedAt is timestamp && data.endedAt is timestamp && data.endedAt >= data.startedAt
            && data.sleepType in ['day', 'night']
            && data.wakeCount is number && data.wakeCount >= 0
            && data.quality in ['good', 'average', 'poor']
            && isOptionalString(data, 'location', 200)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validSleep() && validCreateMetadata();
        allow update: if isAllowed() && validSleep() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /diaperRecords/{recordId} {
        function validDiaper() {
          let data = request.resource.data;
          return data.keys().hasOnly(['changedAt', 'diaperType', 'stoolColor', 'stoolConsistency', 'abnormal', 'abnormalDetails', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['changedAt', 'diaperType', 'abnormal', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.changedAt is timestamp
            && data.diaperType in ['wet', 'dirty', 'both', 'dry']
            && isOptionalString(data, 'stoolColor', 100)
            && isOptionalString(data, 'stoolConsistency', 100)
            && data.abnormal is bool
            && isOptionalString(data, 'abnormalDetails', 1000)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validDiaper() && validCreateMetadata();
        allow update: if isAllowed() && validDiaper() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /symptomRecords/{recordId} {
        function validSymptom() {
          let data = request.resource.data;
          return data.keys().hasOnly(['recordedAt', 'temperatureCelsius', 'symptoms', 'otherSymptom', 'severity', 'startedAt', 'endedAt', 'active', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['recordedAt', 'symptoms', 'severity', 'startedAt', 'active', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.recordedAt is timestamp
            && isOptionalNumber(data, 'temperatureCelsius')
            && data.symptoms is list && data.symptoms.size() <= 30
            && isOptionalString(data, 'otherSymptom', 300)
            && data.severity in ['mild', 'moderate', 'severe']
            && data.startedAt is timestamp
            && isOptionalTimestamp(data, 'endedAt')
            && data.active is bool
            && isOptionalString(data, 'notes', 1500);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validSymptom() && validCreateMetadata();
        allow update: if isAllowed() && validSymptom() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /medications/{recordId} {
        function validMedication() {
          let data = request.resource.data;
          return data.keys().hasOnly(['name', 'category', 'dosage', 'unit', 'route', 'frequency', 'scheduledTimes', 'startDate', 'endDate', 'prescribedBy', 'reason', 'active', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['name', 'category', 'dosage', 'scheduledTimes', 'startDate', 'active', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.name is string && data.name.size() > 0 && data.name.size() <= 250
            && data.category in ['vitamin', 'medicine', 'supplement', 'other']
            && data.dosage is string && data.dosage.size() > 0 && data.dosage.size() <= 160
            && isOptionalString(data, 'unit', 80)
            && isOptionalString(data, 'route', 120)
            && isOptionalString(data, 'frequency', 200)
            && data.scheduledTimes is list && data.scheduledTimes.size() <= 24
            && data.startDate is timestamp
            && isOptionalTimestamp(data, 'endDate')
            && isOptionalString(data, 'prescribedBy', 200)
            && isOptionalString(data, 'reason', 1000)
            && data.active is bool
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validMedication() && validCreateMetadata();
        allow update: if isAllowed() && validMedication() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /medicationLogs/{recordId} {
        function validMedicationLog() {
          let data = request.resource.data;
          return data.keys().hasOnly(['medicationId', 'scheduledAt', 'takenAt', 'status', 'reaction', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['medicationId', 'scheduledAt', 'takenAt', 'status', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.medicationId is string && data.medicationId.size() > 0 && data.medicationId.size() <= 200
            && data.scheduledAt is timestamp
            && data.takenAt is timestamp
            && data.status in ['taken', 'missed', 'skipped']
            && isOptionalString(data, 'reaction', 1000)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validMedicationLog() && validCreateMetadata();
        allow update: if isAllowed() && validMedicationLog() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /allergies/{recordId} {
        function validAllergy() {
          let data = request.resource.data;
          return data.keys().hasOnly(['allergen', 'allergyType', 'discoveredAt', 'symptoms', 'severity', 'treatment', 'confirmedByDoctor', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['allergen', 'allergyType', 'discoveredAt', 'severity', 'confirmedByDoctor', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.allergen is string && data.allergen.size() > 0 && data.allergen.size() <= 200
            && data.allergyType in ['food', 'medicine', 'environment', 'other']
            && data.discoveredAt is timestamp
            && isOptionalString(data, 'symptoms', 1000)
            && data.severity in ['mild', 'moderate', 'severe']
            && isOptionalString(data, 'treatment', 1000)
            && data.confirmedByDoctor is bool
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validAllergy() && validCreateMetadata();
        allow update: if isAllowed() && validAllergy() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /milestones/{recordId} {
        function validMilestone() {
          let data = request.resource.data;
          return data.keys().hasOnly(['milestoneName', 'achievedDate', 'category', 'mediaUrl', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['milestoneName', 'achievedDate', 'category', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.milestoneName is string && data.milestoneName.size() > 0 && data.milestoneName.size() <= 250
            && data.achievedDate is timestamp
            && data.category in ['motor', 'language', 'social', 'cognitive', 'other']
            && isOptionalString(data, 'mediaUrl', 1000)
            && isOptionalString(data, 'notes', 1500);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validMilestone() && validCreateMetadata();
        allow update: if isAllowed() && validMilestone() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /teethingRecords/{recordId} {
        function validTeething() {
          let data = request.resource.data;
          return data.keys().hasOnly(['toothPosition', 'symptomStartDate', 'eruptedDate', 'symptoms', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['toothPosition', 'eruptedDate', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.toothPosition is string && data.toothPosition.size() > 0 && data.toothPosition.size() <= 20
            && isOptionalTimestamp(data, 'symptomStartDate')
            && data.eruptedDate is timestamp
            && isOptionalString(data, 'symptoms', 1000)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validTeething() && validCreateMetadata();
        allow update: if isAllowed() && validTeething() && validUpdateMetadata();
        allow delete: if isAllowed();
      }

      match /reminders/{recordId} {
        function validReminder() {
          let data = request.resource.data;
          return data.keys().hasOnly(['title', 'reminderType', 'scheduledAt', 'completed', 'linkedCollection', 'linkedRecordId', 'notes', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.keys().hasAll(['title', 'reminderType', 'scheduledAt', 'completed', 'createdByUid', 'createdByEmail', 'createdAt', 'updatedAt'])
            && data.title is string && data.title.size() > 0 && data.title.size() <= 250
            && data.reminderType in ['vaccination', 'medical_visit', 'follow_up', 'medication', 'vitamin', 'growth', 'other']
            && data.scheduledAt is timestamp
            && data.completed is bool
            && isOptionalString(data, 'linkedCollection', 100)
            && isOptionalString(data, 'linkedRecordId', 200)
            && isOptionalString(data, 'notes', 1000);
        }
        allow read: if isAllowed();
        allow create: if isAllowed() && validReminder() && validCreateMetadata();
        allow update: if isAllowed() && validReminder() && validUpdateMetadata();
        allow delete: if isAllowed();
      }
    }
  }
}
